# 依赖（由 lockfile 重装，勿提交）
node_modules/

# 构建产物（Vite / 扩展打包输出）
dist/
dist-ssr/
*.local

# Vite 缓存
.vite/

# 环境变量（可能含密钥）；示例文件可提交
.env
.env.*
!.env.example

# 日志
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# 测试覆盖率（若以后加 Vitest 等）
coverage/

# TypeScript 增量构建缓存
*.tsbuildinfo

# 操作系统
.DS_Store
Thumbs.db

# 编辑器 / IDE（团队若需共享 .vscode，可删掉下面一行或改为白名单）
.idea/

# 扩展打包可能产生的密钥与离线包（勿入库）
*.pem
*.crx

# claude
.claude/